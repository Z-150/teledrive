generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model config {
  created_at               DateTime @default(now())
  updated_at               DateTime @default(now())
  id                       String   @id @default(uuid())
  invitation_code          String?
  disable_signup           Boolean  @default(false)
  allow_server_storage_use Boolean  @default(false)
}

model files {
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now())
  id                  String    @id @default(uuid())
  name                String
  type                String?
  message_id          String?
  mime_type           String?
  size                BigInt?
  uploaded_at         DateTime?
  upload_progress     Float?
  user_id             String
  parent_id           String?
  deleted_at          DateTime?
  sharing_options     String?
  signed_key          String?
  file_id             String?
  link_id             String?
  forward_info        String?
  link                files?    @relation("filesTofiles_link_id", fields: [link_id], references: [id], onDelete: Cascade)
  parent              files?    @relation("filesTofiles_parent_id", fields: [parent_id], references: [id], onDelete: Cascade)
  users               users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  links               files[]   @relation("filesTofiles_link_id")
  parents             files[]   @relation("filesTofiles_parent_id")
  password            String?

  @@index([link_id])
  @@index([message_id])
  @@index([parent_id])
  @@index([user_id])
}

model rate_limits {
  key    String  @id
  points Int     @default(0)
  expire BigInt?
}

model usages {
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  key        String   @id
  usage      BigInt
  expire     DateTime
}

model users {
  created_at      DateTime  @default(now())
  updated_at      DateTime  @default(now())
  id              String    @id @default(uuid())
  username        String
  name            String?
  email           String?
  tg_id           String?
  plan            String?
  settings        String?
  role            String?
  files           files[]

  @@index([tg_id])
}

model waitings {
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  id         String   @id @default(uuid())
  email      String
}

model registrations {
  id          String   @id @default(uuid())
  tg_username String?
  tg_phone    String?
  tg_id       String?
  ip_address  String
  status      String   @default("PENDING_OTP") // PENDING_OTP, PENDING_ADMIN, APPROVED, REJECTED
  otp         String?
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())
}
