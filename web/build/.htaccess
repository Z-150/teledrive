<IfModule mod_rewrite.c>
  RewriteEngine On

  # Arahkan semua permintaan yang berawalan /api ke server PM2 (port 4000)
  RewriteCond %{REQUEST_URI} ^/api [NC]
  RewriteRule ^(.*)$ http://127.0.0.1:4000/$1 [P,L]

  # Untuk React Router Frontend: Jika file tidak ada, arahkan ke index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [QSA,L]
</IfModule>

<IfModule mod_headers.c>
  Header always unset X-Frame-Options
  Header set Content-Security-Policy "frame-ancestors 'self' https://*.telegram.org https://telegram.org;"
</IfModule>
